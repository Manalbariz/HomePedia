# Copiez ce fichier en `.env` et remplissez les valeurs.

# MongoDB (local ou Atlas)
MONGODB_URI=mongodb://localhost:27017/homepedia

# Secret utilisé pour signer les tokens JWT (longue chaîne aléatoire en prod)
JWT_SECRET=change-me-pour-une-chaine-aleatoire-longue

# Port de l'API
PORT=3001

# Origines CORS autorisées (séparées par des virgules). * = toutes (déconseillé en prod)
CORS_ORIGIN=http://localhost:5173

# Scraping Playwright : 1 pour activer /api/scrape en production
SCRAPE_ENABLED=0

# Kafka (optionnel — voir infra/README.md)
KAFKA_ENABLED=0
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_LISTINGS=homepedia.listing.events
KAFKA_TOPIC_RAW=homepedia.listing.raw
KAFKA_TOPIC_CRAWL=homepedia.listing.crawl
KAFKA_CONSUMER_GROUP=homepedia-listings-consumer
KAFKA_PREPROCESS_GROUP=homepedia-preprocess-consumer
KAFKA_INGEST_GROUP=homepedia-ingest-worker
KAFKA_FROM_BEGINNING=0

# Crawl / ingest (scraping volumétrique)
CRAWL_DELAY_MS=4000
CRAWL_MAX_URLS_PER_PAGE=40
INGEST_DELAY_MS=5000
INGEST_CONCURRENCY=2

# Limite communes pour listings:dvf-volume (alternative à --limit=1000)
# DVF_LIMIT=1000

# Spark similarité (voir pipelines/spark/README.md)
SPARK_SIMILAR_ENABLED=0
SPARK_AUTO_RUN=0
SPARK_USE_DOCKER=1
