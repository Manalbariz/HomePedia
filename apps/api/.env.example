# Copiez ce fichier en `.env` et remplissez les valeurs.

# Chaîne de connexion MongoDB Atlas (remplacez <db_password> par le vrai mot de passe)
MONGODB_URI=mongodb+srv://charlesmarguerite:<db_password>@homepedia.hdr9pjz.mongodb.net/homepedia?appName=homePedia

# Secret utilisé pour signer les tokens JWT (mettez une longue chaîne aléatoire)
JWT_SECRET=change-me-pour-une-chaine-aleatoire-longue

# Port de l'API
PORT=3001

# Kafka (optionnel — voir infra/README.md)
KAFKA_ENABLED=0
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_LISTINGS=homepedia.listing.events
KAFKA_CONSUMER_GROUP=homepedia-listings-consumer
KAFKA_FROM_BEGINNING=0

# Spark similarité (voir pipelines/spark/README.md)
SPARK_SIMILAR_ENABLED=0
SPARK_AUTO_RUN=0
SPARK_USE_DOCKER=1
